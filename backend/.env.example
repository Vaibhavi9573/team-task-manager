DATABASE_URL=postgresql://user:password@localhost:5432/team_task_manager
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Demo admin/member seed data for local testing
# Set to true to create a sample admin portal dataset
SEED_DEMO_DATA=false
ADMIN_EMAIL=admin@teamtask.local
ADMIN_PASSWORD=DemoAdmin@123
MEMBER_EMAIL=member@teamtask.local
MEMBER_PASSWORD=DemoMember@123

# Optional SMTP settings for password reset emails
# If these are missing, the API will return the reset link in the response for local testing
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Team Task Manager <no-reply@example.com>"
